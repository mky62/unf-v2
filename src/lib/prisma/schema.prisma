// prisma/schema.prisma
// Define your database models

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SyncStatus {
  IDLE
  SYNCING
  SUCCESS
  FAILED
}

model User {

  /// Clerk user ID (primary identity)
  id                    String   @id

  /// Public app username
  stageName             String   @unique

 /// GitHub username
  username              String   @unique

 /// GitHub access token
  githubAccessToken     String?    
  githubTokenExpiry     DateTime?


avatarUrl                String?
description              String?
socialLinks              Json?
isPublic                 Boolean  @default(true)

lastSyncedAt             DateTime?
syncStatus               SyncStatus @default(IDLE)

createdAt                DateTime @default(now())
updatedAt                DateTime @updatedAt

repos                    Repo[]

}

model Repo {
  id            String   @id @default(cuid())
  
  /// References Clerk user ID
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Repo metadata
  githubRepoId  Int      @unique
  name          String
  fullName      String   // ownername
  stars         Int      @default(0)
  language      String?
  htmlUrl       String

  cachedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt


 @@index([userId])
 @@unique([userId, name])  // prevents duplicate repo names per user
}