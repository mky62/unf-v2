generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SyncStatus {
  IDLE
  SYNCING
  SUCCESS
  FAILED
}

model User {

  /// Database identity
  id                String   @id @default(cuid())

  /// Clerk identity
  clerkId           String   @unique

  /// Public username inside your app
  stageName         String   @unique

  /// GitHub username
  username          String   @unique

  /// OAuth token
  githubAccessToken String?
  githubTokenExpiry DateTime?

  avatarUrl         String?
  description       String?

  isPublic          Boolean  @default(true)

  /// Sync metadata
  lastSyncedAt      DateTime?
  syncStatus        SyncStatus @default(IDLE)

  /// prevents concurrent sync jobs
  syncLockUntil     DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  repos             Repo[]
  socialLinks       SocialLink[]
  syncJobs          SyncJob[]


  @@index([stageName])
  @@index([clerkId])
  @@index([createdAt])
  }

model Repo {

  id            String   @id @default(cuid())

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// GitHub identity
  githubRepoId  Int      @unique

  name          String
  htmlUrl       String

  description   String?

  stars         Int      @default(0)
  forks         Int      @default(0)
  language      String?

  createdAt     DateTime
  pushedAt      DateTime?

  cachedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([language])
  @@index([stars])
}

model SocialLink {
  id        String @id @default(cuid())

  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform  String? /// "twitter", "linkedin", "portfolio", etc.
  url       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform])
  @@index([userId])
}

model SyncJob {

  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  status    SyncStatus @default(IDLE)

  startedAt DateTime?
  finishedAt DateTime?

  // message if sync failed
  error     String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  }